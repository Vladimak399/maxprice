# Обязательные переменные для MAX webhook и служебных endpoint.
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
ADMIN_SECRET=
PUBLIC_WEBHOOK_URL=

# Обязательна для админки, HR-опросов и базы знаний. Для мониторинга цен не нужна.
DATABASE_URL=

# Куда отправлять итоговые отчеты по росту закупочной цены.
# Достаточно одной переменной: TARGET_CHAT_ID предпочтительнее для отдельного чата отчетов,
# TARGET_USER_ID — если отчеты должны приходить в личку.
TARGET_CHAT_ID=
TARGET_USER_ID=

# Включить временно, чтобы бот прислал chat_id неизвестного рабочего чата в TARGET_*.
ADMIN_NOTIFY_UNKNOWN_CHATS=false

# Рабочие чаты, из которых бот читает сообщения операторов.
# Пример:
# {"123456789":{"name":"Операторы цены","mode":"price_changes","enabled":true,"sendTo":"chat"}}
CHAT_CONFIGS_JSON=
